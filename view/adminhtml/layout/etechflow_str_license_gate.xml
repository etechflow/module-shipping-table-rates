<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="ETechFlow\ShippingTableRates\Block\Adminhtml\UpdateNotice"
                   name="etechflow_str_update_notice_gate"
                   template="ETechFlow_ShippingTableRates::update-notice.phtml"
                   cacheable="false" before="-"/>
            <block class="Magento\Backend\Block\Template"
                   name="etechflow.str.license.gate"
                   template="ETechFlow_ShippingTableRates::license/gate.phtml"/>
        </referenceContainer>
    </body>
</page>
