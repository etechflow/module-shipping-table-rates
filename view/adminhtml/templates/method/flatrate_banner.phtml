</style>

<div class="etf-str-flatrate-banner">
    <div class="etf-icon">&#9888;&#65039;</div>
    <div class="etf-text">
        <strong>Magento's built-in Flat Rate carrier is enabled.</strong>
        <span>It will compete with STR's rules at checkout (customers may see a $5 Flat Rate row next to your calculated rates).</span>
        <small>Current STR behavior: Flat Rate is <?= $escaper->escapeHtml($behaviorLabel); ?>.</small>
    </div>
    <div class="etf-actions">
        <form method="post" action="<?= $escaper->escapeUrl($block->getDisableUrl()); ?>" style="display:inline;">
            <?= $block->getBlockHtml('formkey'); ?>
            <button type="submit" class="etf-btn etf-btn-primary"
                    onclick="return confirm('Disable Magento\'s built-in Flat Rate carrier? STR will become the only shipping carrier on this store. You can re-enable it under Stores -> Configuration -> Sales -> Shipping Methods -> Flat Rate.');">
                Disable Flat Rate
            </button>
        </form>
        <a href="<?= $escaper->escapeUrl($block->getBehaviorConfigUrl()); ?>" class="etf-btn etf-btn-ghost">
            Change Behavior
        </a>
    </div>
</div>
