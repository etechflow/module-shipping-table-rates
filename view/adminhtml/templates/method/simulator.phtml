             aria-live="polite"
             aria-busy="false"
             aria-label="<?= $escaper->escapeHtmlAttr(__('Simulation result')) ?>"></div>
    </fieldset>
</div>

<script>
(function() {
    var widgetId   = <?= json_encode($widgetId) ?>;
    var simulateUrl = <?= json_encode($block->getSimulateUrl()) ?>;
    var formKey    = <?= json_encode($block->getFormKey()) ?>;
    var methodId   = <?= (int) $block->getMethodId() ?>;
    var labels = {
        loading:   <?= json_encode(__('Running simulation...')->render()) ?>,
        match:     <?= json_encode(__('MATCH')->render()) ?>,
        noMatch:   <?= json_encode(__('NO MATCH')->render()) ?>,
        method:    <?= json_encode(__('Method')->render()) ?>,
        result:    <?= json_encode(__('Result')->render()) ?>,
        cost:      <?= json_encode(__('Cost')->render()) ?>,
        detail:    <?= json_encode(__('Detail')->render()) ?>,
        eta:       <?= json_encode(__('ETA')->render()) ?>,
        days:      <?= json_encode(__('day(s)')->render()) ?>,
        noRule:    <?= json_encode(__('No rate rule satisfies the cart.')->render()) ?>,
        noMethods: <?= json_encode(__('No methods configured.')->render()) ?>,
        error:     <?= json_encode(__('Simulation failed:')->render()) ?>,
        errorPrefix: <?= json_encode(__('Error:')->render()) ?>,
    };

    function $(id) { return document.getElementById(widgetId + '-' + id); }
    function getResultEl() { return document.getElementById(widgetId + '-result'); }

    $('run').addEventListener('click', function() {
        var resultEl = getResultEl();
        var runBtn   = $('run');

        // Loading state
        resultEl.setAttribute('aria-busy', 'true');
        resultEl.className = 'etf-str-sim-result etf-str-sim-result--loading';
        resultEl.innerHTML =
            '<span class="etf-str-spinner" role="presentation" aria-hidden="true"></span>' +
            '<span>' + escapeHtml(labels.loading) + '</span>';
        runBtn.disabled = true;

        var body = new FormData();
        body.append('form_key', formKey);
        body.append('method_id', methodId);
        body.append('country', $('country').value);
        body.append('region', $('region').value);
        body.append('postcode', $('postcode').value);
        body.append('weight', $('weight').value);
        body.append('qty', $('qty').value);
        body.append('subtotal', $('subtotal').value);
        body.append('customer_group', $('customer-group').value);
        body.append('shipping_types', $('shipping-types').value);

        fetch(simulateUrl, { method: 'POST', credentials: 'same-origin', body: body })
            .then(function(r) { return r.json(); })
            .then(function(data) { renderResult(resultEl, data); })
            .catch(function(err) { renderError(resultEl, err); })
            .finally(function() {
                resultEl.setAttribute('aria-busy', 'false');
                runBtn.disabled = false;
            });
    });

    function renderResult(el, data) {
        if (!data.success) {
            el.className = 'etf-str-sim-result etf-str-sim-result--error';
            el.innerHTML = escapeHtml(labels.errorPrefix) + ' ' + escapeHtml(data.error || 'unknown');
            return;
        }
        if (!data.results || data.results.length === 0) {
            el.className = 'etf-str-sim-result etf-str-sim-result--empty';
            el.innerHTML = escapeHtml(labels.noMethods);
            return;
        }

        el.className = 'etf-str-sim-result';

        var html = '<table class="etf-str-table" role="table">';
        html += '<thead><tr>' +
                '<th scope="col">' + escapeHtml(labels.method) + '</th>' +
                '<th scope="col">' + escapeHtml(labels.result) + '</th>' +
                '<th scope="col">' + escapeHtml(labels.cost) + '</th>' +
                '<th scope="col">' + escapeHtml(labels.detail) + '</th>' +
                '</tr></thead><tbody>';

        data.results.forEach(function(r) {
            html += '<tr>';
            html += '<td><strong>' + escapeHtml(r.method_name) +
                    '</strong><div class="etf-str-table__id">' + escapeHtml(r.method_code) + '</div></td>';
            if (r.matched) {
                html += '<td><span class="etf-str-badge etf-str-badge--success">' + escapeHtml(labels.match) + '</span></td>';
                html += '<td><strong>' + parseFloat(r.total_cost).toFixed(2) + '</strong></td>';
                var detail = '<div class="etf-str-sim-detail">';
                if (r.delivery_days) {
                    detail += escapeHtml(labels.eta) + ': ' + r.delivery_days + ' ' + escapeHtml(labels.days) + '<br>';
                }
                if (r.comment) {
                    detail += '<span class="etf-str-sim-detail__comment">' + escapeHtml(r.comment) + '</span><br>';
                }
                r.winners.forEach(function(w) {
                    detail += '<span class="etf-str-sim-detail__rule">rate_id=' + w.rate_id +
                              ' shipping_type=' + escapeHtml(w.shipping_type || '(any)') +
                              ' &mdash; ' + escapeHtml(w.formula) + '</span><br>';
                });
                detail += '</div>';
                html += '<td>' + detail + '</td>';
            } else {
                html += '<td><span class="etf-str-badge etf-str-badge--error">' + escapeHtml(labels.noMatch) + '</span></td>';
                html += '<td><span class="etf-str-state-inactive">&mdash;</span></td>';
                html += '<td><span class="etf-str-state-inactive">' + escapeHtml(labels.noRule) + '</span></td>';
            }
            html += '</tr>';
        });
        html += '</tbody></table>';
        el.innerHTML = html;
    }

    function renderError(el, err) {
        el.className = 'etf-str-sim-result etf-str-sim-result--error';
        el.innerHTML = escapeHtml(labels.error) + ' ' + escapeHtml(err.message || err);
    }

    function escapeHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
            return ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' })[c];
        });
    }
})();
</script>
