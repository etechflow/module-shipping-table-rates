<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Register the v1.0 CLI simulate command: bin/magento etechflow:str:simulate -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="etechflow_str_simulate"
                      xsi:type="object">ETechFlow\ShippingTableRates\Console\Command\SimulateCommand</item>
                <item name="etechflow_str_verify"
                      xsi:type="object">ETechFlow\ShippingTableRates\Console\Command\VerifyCommand</item>
                <item name="etechflow_str_perf"
                      xsi:type="object">ETechFlow\ShippingTableRates\Console\Command\PerfCommand</item>
            </argument>
        </arguments>
    </type>

    <!--
      Smart-fallback / hide gate for Magento's built-in flatrate carrier.
      Reads the merchant's Flat Rate Behavior config and intercepts
      Flatrate::collectRates() at storefront checkout. Registered in global
      di.xml (not adminhtml) because it affects the storefront carrier query.
    -->
    <type name="Magento\OfflineShipping\Model\Carrier\Flatrate">
        <plugin name="etechflow_str_flatrate_gate"
                type="ETechFlow\ShippingTableRates\Plugin\Carrier\FlatrateGatePlugin"
                sortOrder="10"/>
    </type>

</config>
